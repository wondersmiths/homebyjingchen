{
  "_comment": "Astra Pro Customizer Settings — Import via Appearance → Customize or apply manually",
  "_instructions": "These are the exact values to set in Appearance → Customize for each setting",

  "global_colors": {
    "primary":          "#1B2A4A",
    "accent":           "#C9A84C",
    "heading_text":     "#1B2A4A",
    "body_text":        "#333333",
    "link":             "#1B2A4A",
    "link_hover":       "#C9A84C",
    "light_background": "#F5F5F5",
    "white_background": "#FFFFFF"
  },

  "typography": {
    "body": {
      "font_family": "Inter",
      "font_weight": "400",
      "font_size": "16px",
      "line_height": "1.7",
      "text_transform": "none"
    },
    "headings": {
      "font_family": "Playfair Display",
      "font_weight": "700",
      "text_transform": "none"
    },
    "h1": { "font_size": "48px", "line_height": "1.2", "letter_spacing": "-0.02em" },
    "h2": { "font_size": "36px", "line_height": "1.3", "letter_spacing": "-0.01em" },
    "h3": { "font_size": "28px", "line_height": "1.4", "font_family": "Inter", "font_weight": "600" },
    "h4": { "font_size": "22px", "line_height": "1.4", "font_family": "Inter", "font_weight": "600" }
  },

  "header": {
    "layout": "Header Builder",
    "logo_width": "160px",
    "primary_menu_font_family": "Inter",
    "primary_menu_font_weight": "600",
    "primary_menu_font_size": "15px",
    "primary_menu_color": "#1B2A4A",
    "primary_menu_hover_color": "#C9A84C",
    "header_button_1": {
      "text": "Schedule a Call",
      "link": "/contact/",
      "background": "#C9A84C",
      "color": "#FFFFFF",
      "border_radius": "6px",
      "hover_background": "#B8973E"
    },
    "phone_display": "(408) XXX-XXXX"
  },

  "buttons": {
    "font_family": "Inter",
    "font_weight": "700",
    "font_size": "16px",
    "text_transform": "none",
    "letter_spacing": "0.03em",
    "background": "#C9A84C",
    "text_color": "#FFFFFF",
    "border_radius": "6px",
    "padding_top": "16px",
    "padding_bottom": "16px",
    "padding_left": "32px",
    "padding_right": "32px",
    "hover_background": "#B8973E",
    "hover_text_color": "#FFFFFF"
  },

  "footer": {
    "background": "#1B2A4A",
    "text_color": "#FFFFFF",
    "link_color": "rgba(255,255,255,0.8)",
    "link_hover_color": "#C9A84C",
    "columns": 4,
    "column_1": "Logo + tagline + DRE license",
    "column_2": "Quick Links: Home, Buy, Sell, Communities, Contact",
    "column_3": "Phone, Email, Office Address",
    "column_4": "Social icons: Instagram, Facebook, LinkedIn, YouTube",
    "below_footer": "© 2026 Jing Chen, Realtor. DRE# XXXXXXX. Equal Housing Opportunity."
  },

  "container": {
    "layout": "Full Width / Contained",
    "width": "1200px"
  },

  "sidebar": "No Sidebar"
}
